# Server
PORT=8080

# Upstream API
UPSTREAM_API_KEY=your-api-key

# DynamoDB
TABLE_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1

# Anthropic OAuth
ANTHROPIC_CLIENT_ID=your-client-id
ANTHROPIC_REFRESH_TOKEN=your-refresh-token

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Keycloak
KEYCLOAK_ISSUER=https://your-keycloak/realms/your-realm
KEYCLOAK_JWKS_URL=https://your-keycloak/realms/your-realm/protocol/openid-connect/certs
